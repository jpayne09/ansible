<powershell>
# ============================================================
# AWS EC2 Windows User Data - Enterprise Configuration
# Generated by Ansible AWX
# ============================================================

$ErrorActionPreference = "Continue"
$logFile = "C:\Windows\Temp\userdata_setup.log"

function Write-Log {
    param([string]$Message)
    $ts = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    "$ts - $Message" | Out-File -Append -FilePath $logFile
    Write-Output $Message
}

Write-Log "=== Starting User Data Configuration ==="

# -- 1. Create Local Admin Account (svc_ansible) ----------------
Write-Log "Creating local admin account: svc_ansible"
$svcPassword = ConvertTo-SecureString '{{ svc_ansible_password }}' -AsPlainText -Force
try {
    New-LocalUser -Name "svc_ansible" `
                  -Password $svcPassword `
                  -FullName "Ansible Service Account" `
                  -Description "Created by Ansible AWX user_data" `
                  -PasswordNeverExpires `
                  -AccountNeverExpires
    Add-LocalGroupMember -Group "Administrators" -Member "svc_ansible"
    Write-Log "svc_ansible created and added to Administrators"
} catch {
    if ($_.Exception.Message -like "*already exists*") {
        Write-Log "svc_ansible already exists, updating password"
        Set-LocalUser -Name "svc_ansible" -Password $svcPassword
        try { Add-LocalGroupMember -Group "Administrators" -Member "svc_ansible" } catch {}
    } else {
        Write-Log "ERROR creating svc_ansible: $($_.Exception.Message)"
    }
}

# Set Administrator password
Write-Log "Setting Administrator password"
net user Administrator '{{ ec2_win_admin_password }}' /active:yes

# -- 2. Disable Network Location Wizard -------------------------
Write-Log "Disabling Network Location Wizard"

# Registry key to suppress NLW prompt
$nlwPath = "HKLM:\SYSTEM\CurrentControlSet\Control\Network\NewNetworkWindowOff"
if (-not (Test-Path $nlwPath)) {
    New-Item -Path $nlwPath -Force | Out-Null
}

# Set all network profiles to Private (prevents the popup)
Get-NetConnectionProfile | Set-NetConnectionProfile -NetworkCategory Private -ErrorAction SilentlyContinue
Write-Log "Network Location Wizard disabled"

# -- 3. Enable and Configure WinRM ------------------------------
Write-Log "Configuring WinRM"
Set-ExecutionPolicy Unrestricted -Force

winrm quickconfig -q 2>&1 | Out-File -Append $logFile
winrm set winrm/config/service '@{AllowUnencrypted="true"}' 2>&1 | Out-File -Append $logFile
winrm set winrm/config/service/auth '@{Basic="true"}' 2>&1 | Out-File -Append $logFile
winrm set winrm/config/winrs '@{MaxMemoryPerShellMB="1024"}' 2>&1 | Out-File -Append $logFile
winrm set winrm/config '@{MaxTimeoutms="1800000"}' 2>&1 | Out-File -Append $logFile
winrm set winrm/config/service '@{MaxConcurrentOperationsPerUser="12000"}' 2>&1 | Out-File -Append $logFile

Set-Service -Name WinRM -StartupType Automatic
Start-Service WinRM

New-NetFirewallRule -DisplayName "WinRM HTTP" -Direction Inbound -LocalPort 5985 -Protocol TCP -Action Allow -ErrorAction SilentlyContinue
New-NetFirewallRule -DisplayName "WinRM HTTPS" -Direction Inbound -LocalPort 5986 -Protocol TCP -Action Allow -ErrorAction SilentlyContinue
Write-Log "WinRM configured"

# -- 4. Install and Enable OpenSSH Server -----------------------
Write-Log "Installing OpenSSH Server"
try {
    Add-WindowsCapability -Online -Name OpenSSH.Server~~~~0.0.1.0

    Set-Service -Name sshd -StartupType Automatic
    Start-Service sshd

    New-NetFirewallRule -DisplayName "OpenSSH Server (sshd)" `
                        -Direction Inbound `
                        -LocalPort 22 `
                        -Protocol TCP `
                        -Action Allow `
                        -ErrorAction SilentlyContinue

    # Set default shell to PowerShell for SSH sessions
    New-ItemProperty -Path "HKLM:\SOFTWARE\OpenSSH" `
                     -Name DefaultShell `
                     -Value "C:\Windows\System32\WindowsPowerShell\v1.0\powershell.exe" `
                     -PropertyType String `
                     -Force

    Write-Log "OpenSSH Server installed and started"
} catch {
    Write-Log "ERROR installing OpenSSH: $($_.Exception.Message)"
}

# -- 5. Initialize Data Disks (additional EBS volumes) ----------
Write-Log "Initializing additional EBS volumes"
try {
    Start-Sleep -Seconds 10

    $rawDisks = Get-Disk | Where-Object { $_.PartitionStyle -eq 'RAW' -and $_.Number -ne 0 }
    $driveLetter = [char]68  # Start with D:

    foreach ($disk in $rawDisks) {
        Write-Log "Initializing Disk $($disk.Number) as $([char]$driveLetter):"
        Initialize-Disk -Number $disk.Number -PartitionStyle GPT
        New-Partition -DiskNumber $disk.Number -UseMaximumSize -DriveLetter ([char]$driveLetter) | Out-Null
        Format-Volume -DriveLetter ([char]$driveLetter) -FileSystem NTFS -NewFileSystemLabel "Data" -Confirm:$false
        $driveLetter++
    }
    Write-Log "Disk initialization complete"
} catch {
    Write-Log "ERROR initializing disk: $($_.Exception.Message)"
}

# -- 6. Create Standard Directories -----------------------------
@("C:\Scripts", "C:\Logs", "C:\Temp") | ForEach-Object {
    if (-not (Test-Path $_)) { New-Item -Path $_ -ItemType Directory -Force | Out-Null }
}

Write-Log "=== User Data Configuration Complete ==="
</powershell>
