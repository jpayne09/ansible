#!/bin/bash
# ============================================================
# AWS EC2 Linux User Data - Enterprise Configuration
# Generated by Ansible AWX
# ============================================================

set -e
LOG="/var/log/userdata_setup.log"

log() { echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" | tee -a "$LOG"; }

log "=== Starting User Data Configuration ==="

# -- 1. Create service account -----------------------------------
log "Creating svc_ansible service account"
if ! id svc_ansible &>/dev/null; then
    useradd -m -s /bin/bash -G wheel,adm svc_ansible 2>/dev/null || \
    useradd -m -s /bin/bash svc_ansible
    # Add to sudo/wheel group
    usermod -aG sudo svc_ansible 2>/dev/null || usermod -aG wheel svc_ansible 2>/dev/null || true
    log "svc_ansible account created"
else
    log "svc_ansible already exists"
fi

# -- 2. System updates ------------------------------------------
log "Updating system packages"
if command -v yum &>/dev/null; then
    yum update -y -q 2>&1 | tail -5 >> "$LOG"
    yum install -y -q jq git curl wget htop tmux unzip tree 2>&1 | tail -5 >> "$LOG"
elif command -v apt-get &>/dev/null; then
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq 2>&1 >> "$LOG"
    apt-get upgrade -y -qq 2>&1 >> "$LOG"
    apt-get install -y -qq jq git curl wget htop tmux unzip tree 2>&1 >> "$LOG"
fi
log "System packages updated"

# -- 3. Mount data disk (second EBS volume) ----------------------
log "Checking for additional EBS volumes"
DATA_DEVICE=""
for dev in /dev/xvdf /dev/nvme1n1; do
    if [ -b "$dev" ]; then
        DATA_DEVICE="$dev"
        break
    fi
done

if [ -n "$DATA_DEVICE" ]; then
    if ! blkid "$DATA_DEVICE" &>/dev/null; then
        log "Formatting $DATA_DEVICE as ext4"
        mkfs.ext4 -q "$DATA_DEVICE"
    fi
    mkdir -p /data
    if ! grep -q '/data' /etc/fstab; then
        UUID=$(blkid -s UUID -o value "$DATA_DEVICE")
        echo "UUID=$UUID /data ext4 defaults,nofail 0 2" >> /etc/fstab
    fi
    mount -a
    log "Data disk mounted at /data"
else
    log "No additional data disk found"
fi

# -- 4. Create standard directories -----------------------------
mkdir -p /opt/scripts /var/log/ansible /opt/apps /data 2>/dev/null || true

# -- 5. SSH hardening -------------------------------------------
log "Hardening SSH configuration"
sed -i 's/^#\?PermitRootLogin.*/PermitRootLogin prohibit-password/' /etc/ssh/sshd_config
sed -i 's/^#\?MaxAuthTries.*/MaxAuthTries 3/' /etc/ssh/sshd_config
systemctl restart sshd 2>/dev/null || systemctl restart ssh 2>/dev/null || true

log "=== User Data Configuration Complete ==="
