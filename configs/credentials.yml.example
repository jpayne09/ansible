# Azure Service Principal credentials for Cloud Ansible Sandbox
# Copy this to azure_credentials.yml and fill in your actual values
# NEVER commit the actual credentials file to version control

# Azure App Registration (Service Principal) credentials
azure_auth:
  subscription_id: "your-subscription-id"
  client_id: "your-app-registration-client-id"
  client_secret: "your-app-registration-client-secret"
  tenant_id: "your-tenant-id"
  cloud_environment: "AzureCloud"

# GitHub repository information
github:
  repository: "your-github-username/your-repo-name"
  repository_url: "https://github.com/your-github-username/your-repo-name"
  branch: "main"
  use_ssh: false

# Sandbox environment settings
sandbox:
  enabled: true
  environment_name: "cloud-ansible-sandbox"
  isolated_network: true
  cleanup_on_exit: false

# Resource defaults
default_region: "eastus"
default_resource_group: "rg-ansible-sandbox-vms"

# Environment-specific settings
environments:
  sandbox:
    vm_size: "Standard_B2s"
    resource_prefix: "sandbox"
    location: "eastus"
    cleanup: false
  
  dev:
    vm_size: "Standard_B2s"
    resource_prefix: "dev"
    location: "eastus"
  
  staging:
    vm_size: "Standard_B2s"
    resource_prefix: "staging"
    location: "eastus"
  
  prod:
    vm_size: "Standard_D2s_v3"
    resource_prefix: "prod"
    location: "eastus"
